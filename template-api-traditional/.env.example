# Copiar a .env en la raíz del repositorio (no versionar .env).
# En Development, la API carga este archivo al iniciar (dotnet run / Visual Studio).
# Docker Compose también lee .env para las variables (por ejemplo MSSQL_SA_PASSWORD).

# --- docker compose: contraseña del contenedor SQL Server (misma que Password= en la cadena de abajo) ---
MSSQL_SA_PASSWORD=ChangeMe_StrongP@ssw0rd

# Cadena usada por la API cuando se ejecuta LOCAL (Visual Studio / dotnet run).
# Si usas SQL Server en Docker, normalmente será localhost:1433.
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=TemplateDb;User Id=sa;Password=ChangeMe_StrongP@ssw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true

# --- Solo desarrollo local (dotnet run + LocalDB): sustituye la línea ConnectionStrings__ anterior por ---
# ConnectionStrings__DefaultConnection=Server=(localdb)\mssqllocaldb;Database=TemplateDB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true
